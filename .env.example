# ─────────────────────────────────────────────────────────────
# The Global Ledger — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.
# In production, set these in Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Resend Audience ID — https://resend.com/audiences
# (the list new subscribers are added to)
RESEND_AUDIENCE_ID=your_audience_id_here

# The verified "from" address for outgoing email.
# Until your domain is verified you can use Resend's sandbox sender.
NEWSLETTER_FROM="The Global Ledger <onboarding@resend.dev>"
